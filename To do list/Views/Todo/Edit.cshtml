@model TodoApp.Models.TodoItem
@{
    ViewData["Title"] = "Edit Task";
}

<div class="form-page">
    <div class="form-header">
        <a href="/Todo" class="back-link">← Back</a>
        <h2>Edit task</h2>
    </div>
    <form method="post">
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)
        @Html.HiddenFor(m => m.CreatedAt)
        @Html.HiddenFor(m => m.SortOrder)
        <div class="form-group">
            <label>Title *</label>
            @Html.TextBoxFor(m => m.Title, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Title, "", new { @class = "field-error" })
        </div>
        <div class="form-group">
            <label>Description</label>
            @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = "3" })
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Priority</label>
                @Html.DropDownListFor(m => m.Priority, Html.GetEnumSelectList<TodoApp.Models.Priority>(), new { @class = "form-control" })
            </div>
            <div class="form-group">
                <label>Category</label>
                @Html.DropDownListFor(m => m.Category, Html.GetEnumSelectList<TodoApp.Models.Category>(), new { @class = "form-control" })
            </div>
            <div class="form-group">
                <label>Due date</label>
                @Html.TextBoxFor(m => m.DueDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
            </div>
        </div>
        <div class="form-group checkbox-group">
            @Html.CheckBoxFor(m => m.IsCompleted)
            <label asp-for="IsCompleted">Mark as completed</label>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn-primary">Save changes</button>
            <a href="/Todo" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>