@{
    ViewData["Title"] = "Sign in"; Layout = "_Layout";
}

<div class="auth-card">
    <div class="auth-logo">✦ TaskFlow</div>
    <h2>Welcome back</h2>
    <p class="auth-sub">Sign in to your account</p>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-error">Invalid email or password.</div>
    }

    <form method="post" action="/Account/Login">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" class="form-control" placeholder="you@email.com" required />
        </div>
        <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" class="form-control" placeholder="••••••" required />
        </div>
        <label class="remember-label">
            <input type="checkbox" name="rememberMe" /> Remember me
        </label>
        <button type="submit" class="btn-primary full">Sign in</button>
    </form>
    <p class="auth-switch">Don't have an account? <a href="/Account/Register">Register</a></p>
</div>